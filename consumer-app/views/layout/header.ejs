<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <meta name="description" content="FuelIndia — Real-time LPG, CNG, Petrol availability and pre-booking platform for Indian consumers" />

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            brand: { 50:'#fef7ee', 100:'#fdecd3', 200:'#fbd5a5', 300:'#f9b56c', 400:'#f68b30', 500:'#f46b0b', 600:'#e55007', 700:'#be3b09', 800:'#972f0f', 900:'#7a290f' },
            fuel:  { green:'#16a34a', yellow:'#d97706', red:'#dc2626', dark:'#1e293b' }
          }
        }
      }
    }
  </script>

  <!-- Font -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Inter', sans-serif; }
    .gradient-brand { background: linear-gradient(135deg, #f46b0b 0%, #e55007 100%); }
    .stock-high   { background-color:#dcfce7; color:#166534; border:1px solid #bbf7d0; }
    .stock-medium { background-color:#fef9c3; color:#854d0e; border:1px solid #fde68a; }
    .stock-low    { background-color:#fee2e2; color:#991b1b; border:1px solid #fecaca; }
    .slot-full    { background-color:#f3f4f6; color:#9ca3af; cursor:not-allowed; }
    .slot-open    { background-color:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; cursor:pointer; }
    .slot-open:hover { background-color:#dcfce7; }
  </style>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "FuelIndia — Consumer Fuel Management Platform",
    "url": "https://energy-panic-solution-management-demo.netlify.app/",
    "description": "A prototype platform that solves the real-world problem of fuel crowd, panic buying and supply crisis through smart pre-booking of Petrol, LPG cylinders, and CNG slots for Indian consumers.",
    "applicationCategory": "UtilityApplication",
    "operatingSystem": "Web",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "INR"
    },
    "creator": {
      "@type": "Organization",
      "name": "FuelIndia Prototype",
      "url": "https://energy-panic-solution-management-demo.netlify.app/"
    },
    "featureList": [
      "Real-time fuel availability dashboard",
      "Petrol pump QR slot pre-booking",
      "LPG cylinder advance delivery booking",
      "CNG station time-slot management",
      "Unified booking history",
      "Virtual queue system to eliminate physical crowding"
    ],
    "keywords": "fuel booking India, LPG cylinder booking, CNG slot booking, petrol pump queue, fuel scarcity solution, panic buying prevention",
    "inLanguage": "en-IN",
    "isAccessibleForFree": true,
    "abstract": "Educational prototype demonstrating how technology can prevent fuel station crowding, panic buying, and supply crisis through digital pre-booking and real-time availability data."
  }
  </script>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">

<!-- ── PROTOTYPE DISCLAIMER TOP BAR ──────────────────────────── -->
<div class="w-full bg-amber-50 border-b border-amber-200 py-1.5 px-4 text-center text-xs text-amber-800 flex items-center justify-center gap-2 flex-wrap">
  <span class="font-semibold tracking-wide uppercase text-amber-600">⚠ Prototype&nbsp;/ Educational Use Only</span>
  <span class="text-amber-400 hidden sm:inline">|</span>
  <span>This application is a design prototype built for educational &amp; demonstration purposes.</span>
  <span class="text-amber-400 hidden sm:inline">|</span>
  <span>All data displayed is <strong>dummy data</strong> — not connected to any live, commercial, or real-world fuel systems.</span>
</div>

<!-- ── NAVBAR ─────────────────────────────────────────────────── -->
<%- include('../partials/navbar') %>

<!-- ── FLASH MESSAGES ─────────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-4 pt-3">
  <% if (success && success.length) { %>
    <div class="flex items-start gap-3 bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 mb-3 text-sm">
      <span class="text-lg">✅</span>
      <span><%= success[0] %></span>
    </div>
  <% } %>
  <% if (error && error.length) { %>
    <div class="flex items-start gap-3 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 mb-3 text-sm">
      <span class="text-lg">❌</span>
      <span><%= error[0] %></span>
    </div>
  <% } %>
  <% if (info && info.length) { %>
    <div class="flex items-start gap-3 bg-blue-50 border border-blue-200 text-blue-800 rounded-lg px-4 py-3 mb-3 text-sm">
      <span class="text-lg">ℹ️</span>
      <span><%= info[0] %></span>
    </div>
  <% } %>
</div>
