<%- include('../../layout/header') %>

<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-slate-800 mb-1">CNG Stations Finder</h1>
  <p class="text-slate-500 text-sm mb-6">Locate compressed natural gas stations near you</p>

  <% if (crisis && crisis.level >= 3) { %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-4 mb-6">
    <div class="text-red-700 font-semibold text-sm">⚠️ Crisis Level <%= crisis.level %> — CNG may be restricted</div>
    <div class="text-red-600 text-xs mt-1">Contact your nearest CNG station before travelling. Queues may be long.</div>
  </div>
  <% } %>

  <!-- Info Notice -->
  <div class="bg-blue-50 border border-blue-100 rounded-2xl p-5 mb-6">
    <div class="flex items-start gap-3">
      <div class="text-2xl">🔧</div>
      <div>
        <h3 class="font-semibold text-blue-800 text-sm mb-1">CNG Pre-Booking Coming Soon</h3>
        <p class="text-blue-600 text-xs leading-relaxed">
          CNG slot pre-booking is currently under development. This module will allow you to pre-book time slots at CNG stations, 
          avoiding long queue waits. Real-time pressure levels and station capacity will be visible. 
          Walk-in refueling continues to operate normally at all stations.
        </p>
      </div>
    </div>
  </div>

  <!-- Static Station List -->
  <h2 class="text-lg font-semibold text-slate-700 mb-4">Stations in Mumbai</h2>
  <div class="grid gap-4 sm:grid-cols-2">
    <%
    const stations = [
      { id: 'CNG001', name: 'MGL CNG Station — Andheri East', address: 'MIDC Road, Andheri East, Mumbai', pressure: 'High', queue_min: 15, time: '06:00–22:00', type: 'MGL' },
      { id: 'CNG002', name: 'MNGL CNG — Bandra West', address: 'SV Road, Bandra West, Mumbai', pressure: 'Medium', queue_min: 30, time: '24 Hours', type: 'MNGL' },
      { id: 'CNG003', name: 'MGL CNG Station — Goregaon', address: 'WEH Service Road, Goregaon East, Mumbai', pressure: 'Low', queue_min: 55, time: '06:00–23:00', type: 'MGL' },
      { id: 'CNG004', name: 'IOCL CNG — Jogeshwari', address: 'Link Road, Jogeshwari West, Mumbai', pressure: 'High', queue_min: 20, time: '05:00–23:00', type: 'IOCL' }
    ];
    %>
    <% stations.forEach(s => { %>
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
      <div class="flex items-start justify-between mb-3">
        <div>
          <div class="font-semibold text-slate-800 text-sm"><%= s.name %></div>
          <div class="text-xs text-slate-400 mt-0.5"><%= s.address %></div>
        </div>
        <span class="flex-shrink-0 px-2 py-0.5 rounded-full text-xs font-bold
          <%= s.pressure === 'High' ? 'bg-green-100 text-green-600' : s.pressure === 'Medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-600' %>">
          <%= s.pressure %>
        </span>
      </div>

      <div class="grid grid-cols-2 gap-2 mb-3 text-xs">
        <div class="bg-slate-50 rounded-xl px-3 py-2">
          <div class="text-slate-400">Est. Wait</div>
          <div class="font-semibold text-slate-700"><%= s.queue_min %> min</div>
        </div>
        <div class="bg-slate-50 rounded-xl px-3 py-2">
          <div class="text-slate-400">Timing</div>
          <div class="font-semibold text-slate-700"><%= s.time %></div>
        </div>
      </div>

      <div class="flex gap-2">
        <a href="https://maps.google.com/?q=<%= encodeURIComponent(s.address) %>" target="_blank"
          class="flex-1 text-center border border-slate-200 text-slate-600 text-xs font-medium py-2 rounded-xl hover:bg-slate-50 transition-colors">
          📍 Directions
        </a>
        <button disabled class="flex-1 text-center gradient-brand text-white text-xs font-medium py-2 rounded-xl opacity-50 cursor-not-allowed">
          Pre-book (Soon)
        </button>
      </div>
    </div>
    <% }) %>
  </div>

  <!-- CNG FAQ -->
  <div class="mt-8 bg-white rounded-2xl border border-slate-200 p-5">
    <h3 class="font-semibold text-slate-700 mb-4">CNG Quick Facts</h3>
    <div class="space-y-3 text-sm">
      <div class="flex gap-3">
        <span class="text-brand-500 font-bold">₹</span>
        <div><strong>Current CNG Price:</strong> ₹76.59/kg (Mumbai, subject to change)</div>
      </div>
      <div class="flex gap-3">
        <span class="text-brand-500 font-bold">🌿</span>
        <div><strong>Environment:</strong> ~30% lower CO₂ vs petrol, zero particulate emissions</div>
      </div>
      <div class="flex gap-3">
        <span class="text-brand-500 font-bold">⚡</span>
        <div><strong>Fill time:</strong> ~3–8 minutes for standard 4-wheeler CNG kit</div>
      </div>
      <div class="flex gap-3">
        <span class="text-brand-500 font-bold">📞</span>
        <div><strong>MGL Helpline:</strong> 1800-266-9944 (toll-free)</div>
      </div>
    </div>
  </div>
</div>

<%- include('../../layout/footer') %>
