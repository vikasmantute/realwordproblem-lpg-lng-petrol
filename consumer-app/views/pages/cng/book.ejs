<%- include('../../layout/header') %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <a href="/cng/stations" class="text-sm text-slate-500 hover:text-brand-500 mb-6 inline-block">← CNG Stations</a>

  <!-- Station Info -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 mb-5">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-lg font-bold text-slate-800"><%= station.name %></h1>
        <p class="text-xs text-slate-400 mt-0.5"><%= station.address %></p>
        <p class="text-xs text-slate-400"><%= station.operator %> · ₹<%= station.price_per_kg %>/kg · <%= station.operating_hours.open %>–<%= station.operating_hours.close %></p>
      </div>
      <span class="px-2 py-0.5 rounded-full text-xs font-bold
        <%= station.pressure_level === 'High' ? 'bg-green-100 text-green-700' : station.pressure_level === 'Medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
        <%= station.pressure_level %>
      </span>
    </div>
    <!-- Stock Bar -->
    <div class="mt-3">
      <div class="flex justify-between text-xs mb-1">
        <span class="text-slate-400">Gas availability</span>
        <span class="font-semibold <%= station.stock_percent > 60 ? 'text-green-600' : station.stock_percent >= 30 ? 'text-yellow-600' : 'text-red-600' %>">
          <%= station.stock_percent %>%
        </span>
      </div>
      <div class="h-1.5 rounded-full bg-slate-100">
        <div class="h-1.5 rounded-full
          <%= station.stock_percent > 60 ? 'bg-green-400' : station.stock_percent >= 30 ? 'bg-yellow-400' : 'bg-red-400' %>"
          style="width:<%= station.stock_percent %>%"></div>
      </div>
    </div>
  </div>

  <% if (activeBooking) { %>
  <div class="bg-yellow-50 border border-yellow-200 rounded-2xl p-4 mb-5">
    <div class="font-semibold text-yellow-700 text-sm mb-1">⚠️ You have an active CNG booking</div>
    <div class="text-xs text-yellow-600">Token: <strong><%= activeBooking.token %></strong> — <%= activeBooking.station_name %> on <%= activeBooking.slot_date %> at <%= activeBooking.slot_time %></div>
    <div class="flex gap-2 mt-2">
      <a href="/cng/qr/<%= activeBooking.id %>" class="text-xs text-brand-500 font-semibold hover:underline">View QR →</a>
      <span class="text-xs text-slate-400">or cancel it first to book a new slot</span>
    </div>
  </div>
  <% } %>

  <form action="/cng/book" method="POST">
    <input type="hidden" name="station_id" value="<%= station.id %>" />
    <input type="hidden" name="slot_date" id="hiddenDate" value="<%= selectedDate %>" />
    <input type="hidden" name="slot_time" id="hiddenTime" value="" />

    <!-- Date Tabs -->
    <h2 class="font-semibold text-slate-700 mb-3">Select Date</h2>
    <div class="flex gap-2 mb-5 overflow-x-auto pb-1">
      <% bookableDays.forEach(day => { %>
      <button type="button" onclick="selectDate('<%= day %>')" id="date-<%= day %>"
        class="date-tab flex-shrink-0 px-4 py-2.5 rounded-xl border text-xs font-semibold transition-all
          <%= day === selectedDate ? 'gradient-brand text-white border-transparent shadow' : 'bg-white border-slate-200 text-slate-600 hover:border-brand-300' %>">
        <%= formatDate(day) %>
      </button>
      <% }) %>
    </div>

    <!-- Slot Grid -->
    <h2 class="font-semibold text-slate-700 mb-3">Select Time Slot</h2>
    <% if (slots.length === 0) { %>
    <div class="bg-slate-50 rounded-2xl p-6 text-center text-slate-400 text-sm mb-5">
      No slots available for this date. Try another day.
    </div>
    <% } else { %>
    <div class="grid grid-cols-4 sm:grid-cols-6 gap-2 mb-5" id="slot-grid">
      <% slots.forEach(slot => { %>
      <% if (slot.full) { %>
        <div class="text-center py-2.5 rounded-xl bg-slate-50 border border-slate-100 cursor-not-allowed">
          <div class="text-xs font-semibold text-slate-300"><%= slot.time %></div>
          <div class="text-xs text-red-300">Full</div>
        </div>
      <% } else { %>
        <button type="button" onclick="selectSlot('<%= slot.time %>')" id="slot-<%= slot.time %>"
          class="slot-btn text-center py-2.5 rounded-xl border border-slate-200 bg-white hover:border-brand-400 hover:bg-brand-50 transition-all">
          <div class="text-xs font-bold text-slate-700"><%= slot.time %></div>
          <div class="text-xs text-green-500"><%= slot.available %> left</div>
        </button>
      <% } %>
      <% }) %>
    </div>
    <% } %>

    <!-- Booking Form -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 space-y-4">
      <h2 class="font-semibold text-slate-700">Booking Details</h2>

      <!-- Selected Slot Display -->
      <div id="selectedSlotDisplay" class="hidden bg-brand-50 border border-brand-200 rounded-xl px-4 py-2.5">
        <span class="text-xs text-brand-600">Selected slot: </span>
        <span class="text-sm font-bold text-brand-700" id="slotLabel">—</span>
      </div>

      <!-- Vehicle RC -->
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1.5">Vehicle RC Number *</label>
        <% if (consumer.vehicles && consumer.vehicles.filter(v => v.fuel === 'CNG').length > 0) { %>
          <select name="vehicle_rc" id="vehicleRCSelect" required
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300">
            <option value="">Select CNG vehicle</option>
            <% consumer.vehicles.filter(v => v.fuel === 'CNG').forEach(v => { %>
              <option value="<%= v.rc %>" data-type="<%= v.type %>"><%= v.rc %> — <%= v.brand %></option>
            <% }) %>
          </select>
        <% } else { %>
          <input type="text" name="vehicle_rc" placeholder="e.g. MH01AB1234" required
            style="text-transform:uppercase"
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
          <p class="text-xs text-slate-400 mt-1">
            <a href="/profile" class="text-brand-500 hover:underline">Add CNG vehicle to garage</a> for faster booking
          </p>
        <% } %>
      </div>

      <!-- Vehicle Type -->
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1.5">Vehicle Type *</label>
        <div class="grid grid-cols-3 gap-2">
          <% [['2W','Two-Wheeler','~2 kg'],['4W','Four-Wheeler','~10 kg'],['HV','Heavy Vehicle','~50 kg']].forEach(([val, label, hint]) => { %>
          <label class="relative cursor-pointer">
            <input type="radio" name="vehicle_type" value="<%= val %>" class="peer sr-only" onchange="updateMaxKg('<%= val %>')" />
            <div class="border border-slate-200 rounded-xl p-2.5 text-center peer-checked:border-brand-400 peer-checked:bg-brand-50 hover:border-brand-300 transition-all">
              <div class="text-xs font-semibold text-slate-700"><%= label %></div>
              <div class="text-xs text-slate-400 mt-0.5"><%= hint %></div>
            </div>
          </label>
          <% }) %>
        </div>
      </div>

      <!-- KG Requested -->
      <div>
        <label class="block text-xs font-medium text-slate-600 mb-1.5">
          Gas Quantity (kg) *
          <span class="text-slate-400 font-normal">(Max allowed: <span id="maxKgLabel">—</span> kg)</span>
        </label>
        <input type="number" name="kg_requested" id="kgInput" step="0.5" min="0.5" max="50" placeholder="e.g. 5"
          class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300"
          oninput="updateEstimate()" />
      </div>

      <!-- Live Cost Estimate -->
      <div class="bg-slate-50 rounded-xl px-4 py-3 flex justify-between text-sm" id="costEstimate">
        <span class="text-slate-500">Estimated Cost</span>
        <span class="font-bold text-slate-800" id="costLabel">—</span>
      </div>

      <button type="submit" id="submitBtn" disabled
        class="w-full gradient-brand text-white font-semibold py-3 rounded-xl hover:opacity-90 transition-opacity disabled:opacity-40 disabled:cursor-not-allowed">
        Confirm CNG Slot Booking
      </button>
      <p class="text-xs text-slate-400 text-center">Full refund if cancelled before your slot time</p>
    </div>
  </form>
</div>

<script>
const pricePerKg = <%= station.price_per_kg %>;
const maxKgByType = { '2W': <%= station.max_kg_2w %>, '4W': <%= station.max_kg_4w %>, 'HV': <%= station.max_kg_hv %> };

function selectDate(date) {
  window.location.href = '/cng/book/<%= station.id %>?date=' + date;
}

function selectSlot(time) {
  document.querySelectorAll('.slot-btn').forEach(b => {
    b.classList.remove('border-brand-400', 'bg-brand-100', 'shadow');
    b.classList.add('border-slate-200', 'bg-white');
  });
  const btn = document.getElementById('slot-' + time);
  if (btn) {
    btn.classList.add('border-brand-400', 'bg-brand-100', 'shadow');
    btn.classList.remove('border-slate-200', 'bg-white');
  }
  document.getElementById('hiddenTime').value = time;
  document.getElementById('slotLabel').textContent = '<%= selectedDate %> at ' + time;
  document.getElementById('selectedSlotDisplay').classList.remove('hidden');
  checkSubmit();
}

function updateMaxKg(type) {
  const max = maxKgByType[type] || 10;
  document.getElementById('maxKgLabel').textContent = max;
  document.getElementById('kgInput').max = max;
  updateEstimate();
  checkSubmit();
}

function updateEstimate() {
  const kg = parseFloat(document.getElementById('kgInput').value);
  if (!isNaN(kg) && kg > 0) {
    const cost = (kg * pricePerKg).toFixed(2);
    document.getElementById('costLabel').textContent = '₹' + cost;
  } else {
    document.getElementById('costLabel').textContent = '—';
  }
  checkSubmit();
}

function checkSubmit() {
  const time = document.getElementById('hiddenTime').value;
  const kg = parseFloat(document.getElementById('kgInput').value);
  document.getElementById('submitBtn').disabled = !(time && !isNaN(kg) && kg > 0);
}
</script>

<%- include('../../layout/footer') %>
