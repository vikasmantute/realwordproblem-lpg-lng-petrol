<%- include('../../layout/header') %>

<div class="max-w-4xl mx-auto px-4 py-8">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-800">🫙 Book LPG Cylinder</h1>
    <p class="text-slate-500 text-sm mt-1">Doorstep delivery · Digital tracking · OTP confirmation</p>
  </div>

  <!-- Active Booking Warning -->
  <% if (activeBooking) { %>
  <div class="bg-yellow-50 border border-yellow-300 rounded-2xl p-5 mb-6">
    <div class="flex items-start gap-3">
      <span class="text-2xl">⚠️</span>
      <div>
        <div class="font-bold text-yellow-800">You have an active LPG booking</div>
        <div class="text-sm text-yellow-700 mt-1">Token: <strong><%= activeBooking.token %></strong> · Status: <strong><%= activeBooking.status %></strong></div>
        <div class="mt-3 flex gap-3">
          <a href="/lpg/track/<%= activeBooking.id %>" class="text-sm bg-yellow-500 text-white px-4 py-1.5 rounded-lg hover:bg-yellow-600">Track Booking</a>
          <form action="/lpg/cancel/<%= activeBooking.id %>" method="POST" onsubmit="return confirm('Cancel this LPG booking?')">
            <button class="text-sm border border-yellow-400 text-yellow-700 px-4 py-1.5 rounded-lg hover:bg-yellow-100">Cancel to Book New</button>
          </form>
        </div>
      </div>
    </div>
  </div>
  <% } %>

  <div class="grid md:grid-cols-5 gap-6">

    <!-- Distributors -->
    <div class="md:col-span-3 space-y-4">
      <h2 class="font-semibold text-slate-700">Select Distributor Near <%= consumer.pin_code %></h2>

      <% distributors.forEach(dist => { %>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
        <div class="flex items-start justify-between mb-3">
          <div>
            <span class="text-xs font-bold px-2 py-0.5 rounded bg-orange-100 text-orange-700 mb-2 inline-block"><%= dist.omc %></span>
            <h3 class="font-bold text-slate-800"><%= dist.name %></h3>
            <p class="text-xs text-slate-400 mt-0.5"><%= dist.address %></p>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full font-medium
            <%= dist.stock_level === 'High' ? 'bg-green-100 text-green-700' : dist.stock_level === 'Medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
            <%= dist.stock_level %>
          </span>
        </div>

        <!-- Cylinder counts -->
        <div class="grid grid-cols-3 gap-2 mb-3">
          <div class="text-center bg-slate-50 rounded-xl p-2">
            <div class="text-xl font-bold text-slate-700"><%= dist.cylinders_14kg %></div>
            <div class="text-xs text-slate-400">14.2 kg</div>
          </div>
          <div class="text-center bg-slate-50 rounded-xl p-2">
            <div class="text-xl font-bold text-slate-700"><%= dist.cylinders_5kg %></div>
            <div class="text-xs text-slate-400">5 kg</div>
          </div>
          <div class="text-center bg-slate-50 rounded-xl p-2">
            <div class="text-xl font-bold text-slate-700"><%= dist.cylinders_19kg %></div>
            <div class="text-xs text-slate-400">19 kg Comm.</div>
          </div>
        </div>

        <div class="flex items-center justify-between text-xs text-slate-500">
          <span>📅 Next slot: <strong class="text-slate-700"><%= dist.next_slot_available %></strong></span>
          <span>🛵 <%= dist.delivery_agents %> agents</span>
          <span>⭐ <%= dist.rating %></span>
        </div>

        <!-- Delayed confirmation warning -->
        <% if (dist.cylinders_14kg < 60) { %>
        <div class="mt-3 bg-yellow-50 border border-yellow-100 rounded-lg px-3 py-2 text-xs text-yellow-700">
          ⏳ Stock is <%= dist.stock_level.toLowerCase() %>. Confirmation may be delayed by up to 48 hours.
        </div>
        <% } %>
      </div>
      <% }) %>
    </div>

    <!-- Booking Form -->
    <div class="md:col-span-2">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 sticky top-4">
        <h2 class="font-bold text-slate-800 mb-4">Booking Form</h2>

        <form action="/lpg/book" method="POST" class="space-y-4">

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Distributor <span class="text-red-500">*</span></label>
            <select name="distributor_id" required class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
              <option value="">Select distributor</option>
              <% distributors.forEach(d => { %>
              <option value="<%= d.id %>"><%= d.name %> (<%= d.omc %>)</option>
              <% }) %>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Cylinder Type <span class="text-red-500">*</span></label>
            <div class="space-y-2">
              <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-50 has-[:checked]:border-brand-400 has-[:checked]:bg-brand-50">
                <input type="radio" name="cylinder_type" value="14.2kg" checked class="accent-brand-500" />
                <div class="flex-1">
                  <div class="text-sm font-medium text-slate-700">14.2 kg — Domestic</div>
                  <div class="text-xs text-slate-400">Standard household cylinder</div>
                </div>
                <div class="text-sm font-bold text-slate-700">₹895</div>
              </label>
              <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-50 has-[:checked]:border-brand-400 has-[:checked]:bg-brand-50">
                <input type="radio" name="cylinder_type" value="5kg" class="accent-brand-500" />
                <div class="flex-1">
                  <div class="text-sm font-medium text-slate-700">5 kg — Composite</div>
                  <div class="text-xs text-slate-400">Lightweight, portable</div>
                </div>
                <div class="text-sm font-bold text-slate-700">₹480</div>
              </label>
              <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-50 has-[:checked]:border-brand-400 has-[:checked]:bg-brand-50">
                <input type="radio" name="cylinder_type" value="19kg" class="accent-brand-500" />
                <div class="flex-1">
                  <div class="text-sm font-medium text-slate-700">19 kg — Commercial</div>
                  <div class="text-xs text-slate-400">Restaurants & offices</div>
                </div>
                <div class="text-sm font-bold text-slate-700">₹1,850</div>
              </label>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Booking Type</label>
            <select name="booking_type" class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
              <option value="SCHEDULED">📅 Scheduled (Choose date)</option>
              <option value="ASAP">⚡ As Soon As Possible</option>
              <option value="EMERGENCY">🚨 Emergency (priority, higher fee)</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Preferred Delivery Date</label>
            <input type="date" name="preferred_date"
              min="<%= new Date().toISOString().split('T')[0] %>"
              class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400" />
            <p class="text-xs text-slate-400 mt-1">Subject to stock availability at distributor</p>
          </div>

          <!-- Delayed confirmation notice -->
          <div class="bg-blue-50 border border-blue-100 rounded-xl p-3 text-xs text-blue-600">
            ℹ️ If stock is limited, your booking will enter a virtual queue. You will receive a confirmation via SMS once stock is allocated to your order.
          </div>

          <button type="submit" class="w-full gradient-brand text-white font-semibold py-3 rounded-xl hover:opacity-90 transition-opacity">
            Confirm & Pay →
          </button>
          <p class="text-xs text-center text-slate-400">No charge if confirmation is delayed. Cancel anytime for full refund.</p>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../../layout/footer') %>
