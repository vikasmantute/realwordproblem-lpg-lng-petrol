<%- include('../../layout/header') %>

<div class="max-w-5xl mx-auto px-4 py-8">

  <!-- Breadcrumb -->
  <div class="flex items-center gap-2 text-sm text-slate-500 mb-6">
    <a href="/petrol/pumps" class="hover:text-brand-500">Petrol Pumps</a>
    <span>/</span>
    <span class="text-slate-800 font-medium"><%= pump.name %></span>
  </div>

  <div class="grid md:grid-cols-5 gap-6">

    <!-- Left: Slot Picker -->
    <div class="md:col-span-3">

      <!-- Pump Info -->
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 mb-5">
        <div class="flex items-start justify-between">
          <div>
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs font-bold px-2 py-0.5 rounded bg-slate-100 text-slate-600 uppercase"><%= pump.brand %></span>
              <span class="text-xs px-2 py-0.5 rounded-full font-medium
                <%= pump.stock_level === 'High' ? 'bg-green-100 text-green-700' : pump.stock_level === 'Medium' ? 'bg-yellow-100 text-yellow-700' : 'bg-red-100 text-red-700' %>">
                <%= pump.stock_level %> Stock
              </span>
            </div>
            <h1 class="text-lg font-bold text-slate-800"><%= pump.name %></h1>
            <p class="text-sm text-slate-400"><%= pump.address %></p>
          </div>
          <div class="text-right">
            <div class="text-3xl font-bold text-slate-700"><%= pump.stock_percent %>%</div>
            <div class="text-xs text-slate-400">fuel remaining</div>
          </div>
        </div>
        <div class="mt-4 bg-slate-100 rounded-full h-2">
          <div class="h-2 rounded-full <%= pump.stock_percent > 60 ? 'bg-green-400' : pump.stock_percent > 30 ? 'bg-yellow-400' : 'bg-red-400' %>"
            style="width:<%= pump.stock_percent %>%"></div>
        </div>
        <div class="mt-3 flex items-center gap-4 text-xs text-slate-500">
          <span>⭐ <%= pump.rating %></span>
          <span><%= pump.nozzles %> nozzles</span>
          <span><%= pump.slot_duration_minutes %>-min slots</span>
          <span class="font-medium text-slate-700">Max <%= maxLitres %>L per booking</span>
        </div>
      </div>

      <!-- Date Tabs -->
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-5">
        <div class="flex border-b border-slate-200">
          <% days.forEach(d => { %>
          <a href="/petrol/book/<%= pump.id %>?date=<%= d %>"
            class="flex-1 text-center py-3 text-sm font-medium transition-colors
              <%= selectedDate === d ? 'gradient-brand text-white' : 'text-slate-600 hover:bg-slate-50' %>">
            <div class="text-xs opacity-75"><%= new Date(d + 'T00:00:00').toLocaleDateString('en-IN', {weekday:'short'}) %></div>
            <div><%= new Date(d + 'T00:00:00').getDate() %> <%= new Date(d + 'T00:00:00').toLocaleDateString('en-IN', {month:'short'}) %></div>
          </a>
          <% }) %>
        </div>

        <!-- Slot Grid -->
        <div class="p-4">
          <div class="flex items-center justify-between mb-3">
            <span class="text-sm font-semibold text-slate-700">Available Time Slots — <%= formatDate(selectedDate) %></span>
            <div class="flex gap-3 text-xs">
              <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-green-200 inline-block"></span> Available</span>
              <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-gray-200 inline-block"></span> Full</span>
            </div>
          </div>

          <div class="grid grid-cols-4 gap-2" id="slotGrid">
            <% (slotsByDay[selectedDate] || []).forEach(slot => { %>
              <% if (slot.full) { %>
                <div class="text-center py-2 px-1 rounded-lg bg-slate-100 text-slate-400 text-xs">
                  <div class="font-medium"><%= slot.time %></div>
                  <div>FULL</div>
                </div>
              <% } else { %>
                <label class="relative cursor-pointer">
                  <input type="radio" name="slot_time" value="<%= slot.time %>" class="sr-only peer" form="bookingForm" required />
                  <div class="text-center py-2 px-1 rounded-lg border border-green-200 bg-green-50 text-green-700 text-xs peer-checked:bg-green-500 peer-checked:text-white peer-checked:border-green-500 hover:bg-green-100 transition-all">
                    <div class="font-semibold"><%= slot.time %></div>
                    <div><%= slot.available %> left</div>
                  </div>
                </label>
              <% } %>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Booking Form -->
    <div class="md:col-span-2">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 sticky top-4">
        <h2 class="font-bold text-slate-800 mb-4">Booking Details</h2>

        <% if (activeBooking) { %>
        <div class="bg-yellow-50 border border-yellow-200 rounded-xl p-3 mb-4 text-xs text-yellow-700">
          ⚠️ You have an active booking for today. Cancel it first if you want a different slot.
          <a href="/petrol/qr/<%= activeBooking.id %>" class="underline font-semibold block mt-1">View existing booking →</a>
        </div>
        <% } %>

        <form id="bookingForm" action="/petrol/book" method="POST" class="space-y-4">
          <input type="hidden" name="pump_id" value="<%= pump.id %>" />
          <input type="hidden" name="slot_date" value="<%= selectedDate %>" />

          <!-- Vehicle -->
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Vehicle</label>
            <% if (consumer.vehicles && consumer.vehicles.length > 0) { %>
              <select name="vehicle_rc" required class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
                <option value="">Select vehicle</option>
                <% consumer.vehicles.forEach(v => { %>
                  <option value="<%= v.rc %>"><%= v.rc %> — <%= v.brand %> (<%= v.fuel %>)</option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" name="vehicle_rc" placeholder="e.g. MH01AB1234" required pattern="[A-Z]{2}[0-9]{2}[A-Z]{1,2}[0-9]{4}"
                style="text-transform:uppercase"
                class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400" />
              <p class="text-xs text-slate-400 mt-1">
                <a href="/profile" class="text-brand-500 hover:underline">Add vehicle to garage</a> for faster booking
              </p>
            <% } %>
          </div>

          <!-- Fuel Grade -->
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Fuel Grade</label>
            <div class="space-y-2">
              <% pump.fuel_grades.forEach((g, i) => { %>
              <label class="flex items-center gap-3 p-3 border border-slate-200 rounded-xl cursor-pointer hover:bg-slate-50 has-[:checked]:border-brand-400 has-[:checked]:bg-brand-50">
                <input type="radio" name="fuel_grade" value="<%= g.grade %>" <%= i === 0 ? 'checked' : '' %> required class="accent-brand-500" />
                <div class="flex-1">
                  <div class="text-sm font-medium text-slate-700"><%= g.grade %></div>
                  <div class="text-xs text-slate-400"><%= g.stock_litres.toLocaleString('en-IN') %>L available</div>
                </div>
                <div class="text-sm font-bold text-slate-800">₹<%= g.price_per_litre %>/L</div>
              </label>
              <% }) %>
            </div>
          </div>

          <!-- Quantity -->
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">
              Quantity (litres) <span class="text-slate-400 font-normal">— max <%= maxLitres %>L</span>
            </label>
            <input type="number" name="quantity_litres" min="1" max="<%= maxLitres %>" step="0.5"
              value="<%= (consumer.vehicles && consumer.vehicles[0]) ? consumer.vehicles[0].preferred_quantity : 10 %>"
              required
              class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400" />
          </div>

          <!-- Slot reminder -->
          <div class="bg-blue-50 border border-blue-100 rounded-xl p-3 text-xs text-blue-600">
            ⏰ Select a time slot from the calendar on the left before confirming.
          </div>

          <!-- Price estimate -->
          <div class="bg-slate-50 rounded-xl p-3">
            <div class="flex justify-between text-sm text-slate-600 mb-1">
              <span>Estimated Amount</span>
              <span id="priceEst">—</span>
            </div>
            <div class="text-xs text-slate-400">Price locked at booking time. No surge pricing.</div>
          </div>

          <button type="submit" class="w-full gradient-brand text-white font-semibold py-3 rounded-xl hover:opacity-90 transition-opacity">
            Pay & Confirm Booking →
          </button>
          <p class="text-xs text-center text-slate-400">Secure payment · QR generated instantly after confirmation</p>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
  // Live price estimate
  const qtyInput  = document.querySelector('input[name="quantity_litres"]');
  const gradeInputs = document.querySelectorAll('input[name="fuel_grade"]');
  const priceMap  = {};
  <% pump.fuel_grades.forEach(g => { %>
  priceMap['<%= g.grade %>'] = <%= g.price_per_litre %>;
  <% }) %>

  function updatePrice() {
    const grade = document.querySelector('input[name="fuel_grade"]:checked');
    const qty   = parseFloat(qtyInput.value) || 0;
    if (grade && priceMap[grade.value] && qty > 0) {
      const total = (priceMap[grade.value] * qty).toFixed(2);
      document.getElementById('priceEst').textContent = '₹' + parseFloat(total).toLocaleString('en-IN', {minimumFractionDigits: 2});
    }
  }
  qtyInput.addEventListener('input', updatePrice);
  gradeInputs.forEach(i => i.addEventListener('change', updatePrice));
  updatePrice();
</script>

<%- include('../../layout/footer') %>
