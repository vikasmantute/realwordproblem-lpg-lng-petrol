<%- include('../layout/header') %>

<div class="min-h-[60vh] flex items-center justify-center px-4 py-12">
  <div class="text-center">
    <div class="w-16 h-16 bg-red-100 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-5">⚠️</div>
    <h1 class="text-2xl font-bold text-slate-700 mb-2"><%= title || 'Something went wrong' %></h1>
    <p class="text-slate-400 text-sm mb-8 max-w-sm mx-auto">
      <%= message || 'An unexpected error occurred. Our team has been notified. Please try again.' %>
    </p>
    <div class="flex gap-3 justify-center">
      <a href="/" class="gradient-brand text-white font-semibold px-6 py-2.5 rounded-xl hover:opacity-90 transition-opacity">
        Go Home
      </a>
      <a href="javascript:history.back()" class="border border-slate-200 text-slate-600 font-semibold px-6 py-2.5 rounded-xl hover:bg-slate-50 transition-colors">
        Go Back
      </a>
    </div>
    <div class="mt-6 text-xs text-slate-300">FuelEco Platform · Error Reference</div>
  </div>
</div>

<%- include('../layout/footer') %>
