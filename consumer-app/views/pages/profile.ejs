<%- include('../layout/header') %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold text-slate-800 mb-6">My Profile</h1>

  <!-- Profile Info -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-5">
    <div class="gradient-brand text-white p-5 flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-white/20 flex items-center justify-center text-2xl font-bold">
        <%= consumer.name.charAt(0).toUpperCase() %>
      </div>
      <div>
        <div class="text-lg font-bold"><%= consumer.name %></div>
        <div class="text-orange-200 text-sm">+91 <%= consumer.mobile %></div>
        <div class="text-orange-200 text-xs mt-0.5">Consumer ID: <%= consumer.id %></div>
      </div>
      <div class="ml-auto text-right">
        <div class="bg-white/20 rounded-xl px-3 py-1">
          <div class="text-xs opacity-75">Priority</div>
          <div class="font-bold text-lg"><%= consumer.priority_category || 'P4' %></div>
        </div>
      </div>
    </div>

    <div class="p-5 grid grid-cols-2 gap-4 text-sm">
      <div>
        <div class="text-xs text-slate-400 mb-0.5">Email</div>
        <div class="text-slate-700"><%= consumer.email || '—' %></div>
      </div>
      <div>
        <div class="text-xs text-slate-400 mb-0.5">City</div>
        <div class="text-slate-700"><%= consumer.city %>, <%= consumer.state %></div>
      </div>
      <div>
        <div class="text-xs text-slate-400 mb-0.5">PIN Code</div>
        <div class="text-slate-700"><%= consumer.pin_code %></div>
      </div>
      <div>
        <div class="text-xs text-slate-400 mb-0.5">Category</div>
        <div class="text-slate-700 capitalize"><%= (consumer.category || 'general').replace('_', ' ') %></div>
      </div>
      <div>
        <div class="text-xs text-slate-400 mb-0.5">Property Type</div>
        <div class="text-slate-700 capitalize"><%= consumer.property_type || '—' %></div>
      </div>
      <div>
        <div class="text-xs text-slate-400 mb-0.5">Subsidy Enrolled</div>
        <div class="text-slate-700"><%= consumer.pmuy ? '✅ Yes (PMUY)' : 'No' %></div>
      </div>
    </div>
  </div>

  <!-- Update Profile Form -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 mb-5">
    <h2 class="font-semibold text-slate-700 mb-4">Update Profile</h2>
    <form action="/profile/update" method="POST" class="space-y-3">
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Full Name</label>
          <input type="text" name="name" value="<%= consumer.name %>" required
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Email</label>
          <input type="email" name="email" value="<%= consumer.email || '' %>"
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">City</label>
          <input type="text" name="city" value="<%= consumer.city %>" required
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">State</label>
          <input type="text" name="state" value="<%= consumer.state %>" required
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">PIN Code</label>
          <input type="text" name="pin_code" value="<%= consumer.pin_code %>" required maxlength="6"
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-600 mb-1">Address</label>
          <input type="text" name="address" value="<%= consumer.address || '' %>"
            class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
        </div>
      </div>
      <button type="submit" class="gradient-brand text-white text-sm font-semibold px-6 py-2.5 rounded-xl hover:opacity-90 transition-opacity">
        Save Changes
      </button>
    </form>
  </div>

  <!-- Vehicle Garage -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 mb-5">
    <h2 class="font-semibold text-slate-700 mb-4">🚗 Vehicle Garage</h2>

    <% if (consumer.vehicles && consumer.vehicles.length > 0) { %>
    <div class="space-y-2 mb-4">
      <% consumer.vehicles.forEach(v => { %>
      <div class="flex items-center justify-between bg-slate-50 rounded-xl px-4 py-3">
        <div>
      <div class="font-mono font-bold text-sm text-slate-700"><%= v.rc %></div>
          <span class="text-xs text-slate-400 ml-2"><%= v.type %> · <%= v.fuel %> · <%= v.tank_capacity %>L</span>
        </div>
        <form action="/profile/vehicle/remove" method="POST" onsubmit="return confirm('Remove this vehicle?')">
          <input type="hidden" name="rc" value="<%= v.rc %>" />
          <button class="text-red-400 text-xs hover:text-red-600 font-medium">Remove</button>
        </form>
      </div>
      <% }) %>
    </div>
    <% } else { %>
    <p class="text-slate-400 text-sm mb-4">No vehicles added yet.</p>
    <% } %>

    <!-- Add Vehicle Form -->
    <form action="/profile/vehicle/add" method="POST" class="border border-dashed border-slate-200 rounded-xl p-4">
      <div class="text-xs font-semibold text-slate-500 mb-3">Add New Vehicle</div>
      <div class="grid grid-cols-2 gap-3 mb-3">
        <div>
          <label class="block text-xs text-slate-500 mb-1">RC Number *</label>
          <input type="text" name="rc" placeholder="MH01AB1234" required
            class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300 uppercase" />
        </div>
        <div>
          <label class="block text-xs text-slate-500 mb-1">Vehicle Type *</label>
          <select name="type" required class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300">
            <option value="Two-wheeler">Two-Wheeler</option>
            <option value="Four-wheeler">Four-Wheeler</option>
            <option value="Heavy Vehicle">Heavy Vehicle</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-slate-500 mb-1">Fuel Type *</label>
          <select name="fuel" required class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300">
            <option value="Petrol">Petrol</option>
            <option value="Diesel">Diesel</option>
            <option value="CNG">CNG</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-slate-500 mb-1">Tank Capacity (L)</label>
          <input type="number" name="tank_capacity" placeholder="40" min="1" max="200"
            class="w-full border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand-300" />
        </div>
      </div>
      <button type="submit" class="w-full border border-brand-300 text-brand-600 text-xs font-semibold py-2 rounded-xl hover:bg-brand-50 transition-colors">
        + Add Vehicle
      </button>
    </form>
  </div>

  <!-- Subsidy & Credits -->
  <div class="grid grid-cols-2 gap-4">
    <div class="bg-white rounded-2xl border border-slate-200 p-4">
      <h3 class="text-xs font-semibold text-slate-500 mb-3">LPG Subsidy</h3>
      <% if (consumer.pmuy) { %>
      <div class="text-green-600 font-semibold text-sm">✅ Enrolled</div>
      <div class="text-xs text-slate-500 mt-1">PMUY / BPL Beneficiary</div>
      <div class="text-slate-700 text-sm mt-1">₹<%= consumer.subsidy_balance || 0 %> balance</div>
      <% } else { %>
      <div class="text-slate-500 text-sm">Not enrolled</div>
      <a href="#" class="text-xs text-brand-500 hover:underline mt-1 block">Apply for PMUY →</a>
      <% } %>
    </div>
    <div class="bg-white rounded-2xl border border-slate-200 p-4">
      <h3 class="text-xs font-semibold text-slate-500 mb-3">Loyalty Credits</h3>
      <div class="text-2xl font-bold text-brand-500"><%= consumer.loyalty_points || 0 %></div>
      <div class="text-xs text-slate-500 mt-1">Points earned</div>
      <div class="text-xs text-slate-400 mt-1">₹<%= Math.floor((consumer.loyalty_points || 0) / 10) %> redeemable value</div>
      <div class="text-xs text-slate-400 mt-1">Platform credit: ₹<%= consumer.platform_credit || 0 %></div>
    </div>
  </div>
</div>

<%- include('../layout/footer') %>
