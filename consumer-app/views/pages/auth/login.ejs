<%- include('../../layout/header') %>

<div class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-md">

    <!-- Logo -->
    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 text-2xl font-bold text-slate-800">
        <span class="text-3xl">⛽</span>
        <span>Fuel<span class="text-brand-500">India</span></span>
      </a>
      <p class="text-slate-500 mt-2 text-sm">Consumer Portal — Secure Login</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
      <h2 class="text-xl font-bold text-slate-800 mb-1">Welcome back</h2>
      <p class="text-slate-500 text-sm mb-6">Log in to manage your fuel bookings</p>

      <form action="/auth/login" method="POST" class="space-y-5">

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1.5">Mobile Number</label>
          <div class="flex">
            <span class="flex items-center px-3 bg-slate-100 border border-r-0 border-slate-300 rounded-l-lg text-slate-500 text-sm">+91</span>
            <input
              type="tel"
              name="mobile"
              maxlength="10"
              pattern="[0-9]{10}"
              placeholder="9876543210"
              required
              class="flex-1 px-4 py-2.5 border border-slate-300 rounded-r-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent"
            />
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1.5">
            <label class="block text-sm font-medium text-slate-700">Password</label>
            <a href="#" class="text-xs text-brand-500 hover:underline">Forgot password?</a>
          </div>
          <input
            type="password"
            name="password"
            placeholder="Enter your password"
            required
            class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent"
          />
        </div>

        <button type="submit" class="w-full gradient-brand text-white font-semibold py-3 rounded-xl hover:opacity-90 transition-opacity">
          Log In to FuelIndia
        </button>
      </form>

      <div class="mt-6 pt-5 border-t border-slate-100 text-center">
        <p class="text-sm text-slate-600">
          New to FuelIndia?
          <a href="/auth/register" class="text-brand-500 font-semibold hover:underline ml-1">Create free account →</a>
        </p>
      </div>

      <!-- Demo hint -->
      <div class="mt-4 bg-blue-50 border border-blue-100 rounded-lg p-3">
        <p class="text-xs text-blue-600 font-medium mb-1">🧪 Demo Account</p>
        <p class="text-xs text-blue-500">Mobile: <strong>9876543210</strong> &nbsp; Password: <strong>password123</strong></p>
      </div>
    </div>

    <p class="text-center text-xs text-slate-400 mt-6">
      🔒 Your data is encrypted and secure · FuelIndia v1.0
    </p>

  </div>
</div>

<%- include('../../layout/footer') %>
