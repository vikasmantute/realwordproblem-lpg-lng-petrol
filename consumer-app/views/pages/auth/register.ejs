<%- include('../../layout/header') %>

<div class="min-h-screen flex items-center justify-center py-12 px-4">
  <div class="w-full max-w-lg">

    <div class="text-center mb-8">
      <a href="/" class="inline-flex items-center gap-2 text-2xl font-bold text-slate-800">
        <span class="text-3xl">⛽</span>
        <span>Fuel<span class="text-brand-500">India</span></span>
      </a>
      <p class="text-slate-500 mt-2 text-sm">Create your free consumer account</p>
    </div>

    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
      <h2 class="text-xl font-bold text-slate-800 mb-1">Create Account</h2>
      <p class="text-slate-500 text-sm mb-6">Register to book petrol slots, LPG cylinders & more</p>

      <form action="/auth/register" method="POST" class="space-y-4">

        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Full Name <span class="text-red-500">*</span></label>
            <input type="text" name="name" placeholder="Ramesh Kumar" required
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Mobile <span class="text-red-500">*</span></label>
            <div class="flex">
              <span class="flex items-center px-3 bg-slate-100 border border-r-0 border-slate-300 rounded-l-lg text-slate-500 text-xs">+91</span>
              <input type="tel" name="mobile" maxlength="10" pattern="[0-9]{10}" placeholder="9876543210" required
                class="flex-1 px-3 py-2.5 border border-slate-300 rounded-r-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Email</label>
            <input type="email" name="email" placeholder="you@email.com"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Password <span class="text-red-500">*</span></label>
            <input type="password" name="password" placeholder="Min. 6 characters" required minlength="6"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Confirm Password <span class="text-red-500">*</span></label>
            <input type="password" name="confirm_password" placeholder="Re-enter password" required
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div class="col-span-2">
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Address</label>
            <input type="text" name="address" placeholder="Flat/House, Street, Area"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">City</label>
            <input type="text" name="city" placeholder="Mumbai"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">PIN Code <span class="text-red-500">*</span></label>
            <input type="text" name="pin_code" maxlength="6" pattern="[0-9]{6}" placeholder="400069" required
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">State</label>
            <input type="text" name="state" placeholder="Maharashtra"
              class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-transparent" />
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5">Property Type</label>
            <select name="property_type" class="w-full px-4 py-2.5 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-brand-400">
              <option value="Domestic">Domestic</option>
              <option value="Commercial">Commercial</option>
              <option value="Industrial">Industrial</option>
            </select>
          </div>
        </div>

        <div class="pt-2">
          <button type="submit" class="w-full gradient-brand text-white font-semibold py-3 rounded-xl hover:opacity-90 transition-opacity">
            Create Free Account →
          </button>
        </div>

        <p class="text-xs text-slate-400 text-center">
          By registering you agree to our Terms of Service. Your data is protected under IT Act 2000.
        </p>
      </form>

      <div class="mt-5 pt-5 border-t border-slate-100 text-center">
        <p class="text-sm text-slate-600">
          Already have an account?
          <a href="/auth/login" class="text-brand-500 font-semibold hover:underline ml-1">Log in →</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('../../layout/footer') %>
